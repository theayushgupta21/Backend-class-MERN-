<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <title>Document</title>

</head>

<body>
    <div class="main w-full min-h-screen bg-zinc-900 text-amber-300">
        <div class="form p-10 text-white">
            <form action="/create" method="post">
                <input class="block  w-full rounded-lg outline-none px-5 py-3 bg-zinc-800" type="text"
                    placeholder="notes" name="title">
                <textarea class="block w-full rounded-lg  outline-none mt-3 px-5 py-2 resize-none bg-zinc-800"
                    placeholder="write your task details" name="details"></textarea>
                <input class="mt-2 bg-blue-600 px-5 py-2" type="submit" value="create task">
            </form>

        </div>
        <div class="task p-10 flex gap-5 flex-wrap">
            <% if(files.length> 0){ %>
                <%files.forEach(function(val) { %>
                    <div class="task w-72 round-lg outline-none px-3 py-4 bg-zinc-800">
                        <h1 class="text-white text-3xl tracking-tighter">
                            <%= val %>
                        </h1>
                        <a class="text-blue-500 inline-block mt-3" href="/file/<%= val %>">read more.</a>

                    </div>

                    <% }) %>
                        <% }else { %>
                            <h3>No tasks found.</h3>


                            <% } %>


        </div>
    </div>
</body>

</html>